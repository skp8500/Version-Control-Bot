# Port the API server listens on (Render sets PORT automatically)
PORT=3001

# Neon PostgreSQL connection string
# Get this from your Neon project dashboard: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Secret used to sign JWT tokens — use a long random string in production
SESSION_SECRET=change-me-to-a-random-secret

# Groq API key for AI features: https://console.groq.com
GROQ_API_KEY=gsk_...

# Comma-separated list of allowed frontend origins (e.g. your Vercel URL)
# Leave empty to allow all origins (not recommended for production)
CORS_ORIGIN=https://your-app.vercel.app
