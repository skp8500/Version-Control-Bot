# ─────────────────────────────────────────────────────────────────────────────
# mygit — local development environment
# Copy this file to `.env` and fill in the values. The start script
# (scripts/start.sh) loads `.env` automatically.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Postgres connection string.
#
# Easiest option (free, zero install): create a database on Neon
#   https://neon.tech  →  Create project  →  copy the connection string.
#   Example: postgres://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require
#
# Local Postgres example:
#   postgres://postgres:postgres@localhost:5432/mygit
DATABASE_URL=

# RECOMMENDED — secret used to sign auth (JWT) cookies/tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# OPTIONAL — enables AI-powered commit explain & terminal chat.
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# OPTIONAL — ports. Defaults shown.
PORT=5000
API_PORT=3001

# OPTIONAL — when the frontend and backend run on different origins
# (e.g. Vercel frontend + Render backend), comma-separate the allowed
# origins here. Leave empty to allow all (fine for local dev).
CORS_ORIGIN=

# OPTIONAL — where per-repo working directories are stored on disk.
# Defaults to ./mygit-workspaces in the project root.
MYGIT_WORKSPACES_ROOT=

# OPTIONAL — log verbosity for the API server: trace|debug|info|warn|error
LOG_LEVEL=info
